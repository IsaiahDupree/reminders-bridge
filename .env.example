# Local config used by the kit (kit/register-connector.mjs) and the e2e test.
# Copy to .env.local and fill in. NEVER commit .env.local.

# RemindersBridge server base URL (your Vercel deployment, or the hosted one)
NB_SERVER=https://remindersbridge.vercel.app

# The RemindersBridge account the connector signs in as (created on the site)
NB_EMAIL=you@example.com
NB_PASSWORD=your-remindersbridge-password
