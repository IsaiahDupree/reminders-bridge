# Local config used by the kit (kit/register-connector.mjs) and the e2e test.
# Copy to .env.local and fill in. NEVER commit .env.local.

# NotesBridge server base URL (your Vercel deployment, or the hosted one)
NB_SERVER=https://notesbridge.vercel.app

# The NotesBridge account the connector signs in as (created on the site)
NB_EMAIL=you@example.com
NB_PASSWORD=your-notesbridge-password
