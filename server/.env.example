# NotesBridge server (Vercel) environment.
# Copy to .env.local for local dev, or set these in the Vercel project settings.

# --- Storage (Redis-shaped, backed by Supabase Postgres) ---
# The server talks to Supabase via PostgREST RPC (nb_get/nb_set/nb_lpush/...).
# Apply supabase/schema.sql to your project first, then set:
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Auth ---
# Signs all JWTs (session / agent / mcp tokens). Generate with:  openssl rand -hex 32
# REQUIRED in production — the server refuses to boot with the dev default.
JWT_SECRET=change-me-to-a-long-random-string

# Canonical public base URL. Optional; recommended if you run behind a reverse
# proxy that forwards a client-controlled Host/X-Forwarded-Host header (pins the
# host used in verification links + OAuth metadata). Vercel sets this correctly
# on its own, so it's usually unnecessary there.
# PUBLIC_BASE_URL=https://notes.yourdomain.com

# --- Email verification (optional) ---
# If RESEND_API_KEY is unset, email verification is disabled and every account is
# treated as verified (fine for local dev / self-host without email).
# RESEND_API_KEY=re_...
# From address on a domain you've verified in Resend (https://resend.com/domains):
# EMAIL_FROM=NotesBridge <noreply@yourdomain.com>
# Set to 1 to REQUIRE a verified email before an account can connect to ChatGPT.
# Off by default (verification is sent + shown, but not enforced). The reviewer
# demo account and pre-existing accounts are always exempt.
# REQUIRE_EMAIL_VERIFICATION=1
